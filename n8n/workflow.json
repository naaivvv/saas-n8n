      "id": "010373ab-bc51-4e2b-b6c2-404fb8556a31",
      "name": "Apollo Enrichment",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        650,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "keepOnlySet": false,
        "values": {
          "string": [
            {
              "name": "company_name",
              "value": "={{ $json.organization?.name ?? 'Unknown' }}"
            },
