      },
      "id": "2b6ff8f7-7b25-4c07-b353-8b77626359f4",
      "name": "Normalize Enrichment",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={{ $env.GEMINI_API_KEY }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [{\n    \"parts\": [{\n      \"text\": \"You are a Senior SaaS Account Executive analyzing inbound demo requests.\\nGiven the prospect's message and their company profile, assign a purchase\\nintent score from 1-100.\\n\\nScoring Guide:\\n- 90-100: Enterprise buyer, high headcount, explicit urgency, budget signals\\n- 70-89:  Mid-market, clear use case, decision-maker language\\n- 50-69:  Exploratory interest, small-mid company, vague requirements\\n- 30-49:  Likely tire-kicker, personal email, no clear business need\\n- 1-29:   Spam, off-topic, competitor research, student project\\n\\nPROSPECT MESSAGE: {{ $json.original_message }}\\n\\nCOMPANY PROFILE:\\n- Company: {{ $json.company_name }}\\n- Domain: {{ $json.company_domain }}\\n- Employees: {{ $json.employee_count ?? 'Unknown' }}\\n- Industry: {{ $json.industry ?? 'Unknown' }}\\n- Est. Revenue: {{ $json.estimated_revenue ?? 'Unknown' }}\\n\\nRespond with ONLY a valid JSON object:\\n{ \\\"intent_score\\\": <number 1-100>, \\\"reasoning_summary\\\": \\\"<max 2 sentences>\\\" }\"\n    }]\n  }],\n  \"generationConfig\": {\n    \"responseMimeType\": \"application/json\",\n    \"responseSchema\": {\n      \"type\": \"OBJECT\",\n      \"properties\": {\n        \"intent_score\": { \"type\": \"INTEGER\" },\n        \"reasoning_summary\": { \"type\": \"STRING\" }\n      },\n      \"required\": [\"intent_score\", \"reasoning_summary\"]\n    }\n  }\n}",
        "options": {}
      },
      "id": "gemini-intent-score",
      "name": "Gemini Intent Score",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        1050,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let intent_score = 50;\nlet reasoning_summary = \"LLM output validation failed — defaulted.\";\n\ntry {\n  const responseBody = $input.item.json;\n  if (responseBody && responseBody.candidates && responseBody.candidates.length > 0) {\n    const text = responseBody.candidates[0].content.parts[0].text;\n    const parsed = JSON.parse(text);\n    \n    if (Number.isInteger(parsed.intent_score) && parsed.intent_score >= 1 && parsed.intent_score <= 100) {\n      intent_score = parsed.intent_score;\n    }\n    if (typeof parsed.reasoning_summary === 'string') {\n      reasoning_summary = parsed.reasoning_summary;\n    }\n  }\n} catch (e) {\n  // Ignore and use defaults\n}\n\nconst originalData = $(\"Normalize Enrichment\").first().json;\n\n$input.item.json = {\n  ...originalData,\n  intent_score,\n  reasoning_summary\n};\n\nreturn $input.item;"
      },
      "id": "validate-llm-output",
      "name": "Validate LLM Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1250,
        300
      ]
    },
    {
      "parameters": {
        "dataType": "number",
        "value1": "={{ $json.intent_score }}",
        "rules": {
          "rules": [
            {
              "operation": "larger",
              "value2": 80
            },
            {
              "operation": "smallerEqual",
              "value2": 80
            }
          ]
        }
      },
      "id": "switch-node",
      "name": "Route by Intent Score",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [
        1450,
        300
      ]
    },
    {
