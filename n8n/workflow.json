    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [{\n    \"parts\": [{\n      \"text\": \"You are a Senior SaaS Account Executive analyzing inbound demo requests.\\nGiven the prospect's message and their company profile, assign a purchase\\nintent score from 1-100.\\n\\nScoring Guide:\\n- 90-100: Enterprise buyer, high headcount, explicit urgency, budget signals\\n- 70-89:  Mid-market, clear use case, decision-maker language\\n- 50-69:  Exploratory interest, small-mid company, vague requirements\\n- 30-49:  Likely tire-kicker, personal email, no clear business need\\n- 1-29:   Spam, off-topic, competitor research, student project\\n\\nPROSPECT MESSAGE: {{ $json.original_message }}\\n\\nCOMPANY PROFILE:\\n- Company: {{ $json.company_name }}\\n- Domain: {{ $json.company_domain }}\\n- Employees: {{ $json.employee_count ?? 'Unknown' }}\\n- Industry: {{ $json.industry ?? 'Unknown' }}\\n- Est. Revenue: {{ $json.estimated_revenue ?? 'Unknown' }}\\n\\nRespond with ONLY a valid JSON object:\\n{ \\\"intent_score\\\": <number 1-100>, \\\"reasoning_summary\\\": \\\"<max 2 sentences>\\\" }\"\n    }]\n  }],\n  \"generationConfig\": {\n    \"responseMimeType\": \"application/json\",\n    \"responseSchema\": {\n      \"type\": \"OBJECT\",\n      \"properties\": {\n        \"intent_score\": { \"type\": \"INTEGER\" },\n        \"reasoning_summary\": { \"type\": \"STRING\" }\n      },\n      \"required\": [\"intent_score\", \"reasoning_summary\"]\n    }\n  }\n}",
        "options": {}
      },
      "id": "2d184443-3252-4e96-b965-6a934ad529f6",
      "name": "Gemini Intent Score",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        -480,
        -48
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "upFr1pbS4eniQ6Pg",
          "name": "Header Auth account 2"
        },
        "httpQueryAuth": {
          "id": "mbfzf7D5bPtSS9oV",
          "name": "Query Auth account"
        }
      },
      "continueOnFail": true
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let intent_score = 50;\nlet reasoning_summary = \"LLM output validation failed — defaulted.\";\n\ntry {\n  const responseBody = $input.item.json;\n  if (responseBody && responseBody.candidates && responseBody.candidates.length > 0) {\n    const text = responseBody.candidates[0].content.parts[0].text;\n    const parsed = JSON.parse(text);\n    \n    if (Number.isInteger(parsed.intent_score) && parsed.intent_score >= 1 && parsed.intent_score <= 100) {\n      intent_score = parsed.intent_score;\n    }\n    if (typeof parsed.reasoning_summary === 'string') {\n      reasoning_summary = parsed.reasoning_summary;\n    }\n  }\n} catch (e) {\n  // Ignore and use defaults\n}\n\n// 1. Get the enriched company data from the Normalize node\nconst companyData = $(\"Normalize Enrichment\").first().json;\n\n// 2. Get the original user info that was \"lost\" before the HTTP requests\nconst leadData = $(\"Parse Email Domain\").first().json;\n\n// 3. Combine everything into a single, clean JSON object for the rest of the workflow\n$input.item.json = {\n  name: leadData.name,\n  email: leadData.email,\n  original_message: leadData.original_message,\n  company_domain: leadData.company_domain,\n  company_name: companyData.company_name,\n  industry: companyData.industry,\n  employee_count: companyData.employee_count,\n  estimated_revenue: companyData.estimated_revenue,\n  intent_score: intent_score,\n  reasoning_summary: reasoning_summary\n};\n\nreturn $input.item;"
      },
      "id": "d1dc3b72-af34-414a-b40a-21168e7096a1",
      "name": "Validate LLM Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -272,
        -48
      ]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.intent_score }}",
              "operation": "larger",
              "value2": 80
            }
          ]
        }
      },
      "id": "9e6e7d25-9eb5-43f5-9972-0531a31a6312",
      "name": "Route by Intent Score",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
